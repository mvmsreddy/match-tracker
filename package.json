{
  "name": "tennis-match-tracker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "android:sync": "vite build && npx cap sync android",
    "android:install": "npm run android:sync && android\\gradlew.bat installDebug -p android",
    "android:launch": "adb shell am start -n com.matchtrackerpro.app/.MainActivity",
    "android:run": "npm run android:install && npm run android:launch"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "@supabase/supabase-js": "^2.45.4",
    "jspdf": "^2.5.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.8"
  }
}
